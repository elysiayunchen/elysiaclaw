// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

elysiaclaw_CODE_SIGN_STYLE = Automatic
elysiaclaw_DEVELOPMENT_TEAM = YOUR_TEAM_ID

elysiaclaw_APP_BUNDLE_ID = ai.elysiaclaw.client
elysiaclaw_SHARE_BUNDLE_ID = ai.elysiaclaw.client.share
elysiaclaw_ACTIVITY_WIDGET_BUNDLE_ID = ai.elysiaclaw.client.activitywidget
elysiaclaw_WATCH_APP_BUNDLE_ID = ai.elysiaclaw.client.watchkitapp
elysiaclaw_WATCH_EXTENSION_BUNDLE_ID = ai.elysiaclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
elysiaclaw_APP_PROFILE =
elysiaclaw_SHARE_PROFILE =
