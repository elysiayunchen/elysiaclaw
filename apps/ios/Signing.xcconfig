// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

elysiaclaw_CODE_SIGN_STYLE = Manual
elysiaclaw_DEVELOPMENT_TEAM = Y5PE65HELJ

elysiaclaw_APP_BUNDLE_ID = ai.elysiaclaw.client
elysiaclaw_SHARE_BUNDLE_ID = ai.elysiaclaw.client.share
elysiaclaw_WATCH_APP_BUNDLE_ID = ai.elysiaclaw.client.watchkitapp
elysiaclaw_WATCH_EXTENSION_BUNDLE_ID = ai.elysiaclaw.client.watchkitapp.extension
elysiaclaw_ACTIVITY_WIDGET_BUNDLE_ID = ai.elysiaclaw.client.activitywidget

elysiaclaw_APP_PROFILE = ai.elysiaclaw.client Development
elysiaclaw_SHARE_PROFILE = ai.elysiaclaw.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
